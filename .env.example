# SMTP settings for sending patient PDF reports by email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Sender identity
MAIL_FROM_EMAIL=your_email@gmail.com
MAIL_FROM_NAME=DentAI-X Clinic

# Email provider selection: auto | smtp | resend
# auto   -> use Resend if RESEND_API_KEY is set, otherwise SMTP
# smtp   -> force SMTP
# resend -> force Resend API
EMAIL_PROVIDER=auto

# Resend settings (recommended for better inbox placement)
# RESEND_API_KEY=re_xxxxxxxxxxxxx
# RESEND_FROM_EMAIL=reports@yourdomain.com
